h.","Certes, [il]","ne","désespère (pas)","du","[le] soulagement","(donné) par Allâh","sauf","les gens","Mécréants.\""],"88":["Et ensuite, quand","ils sont entrés","auprès de lui,","ils ont dit :","\"Ô","[le] ministre !","Nous a touché","et notre famille","le dommage","et nous sommes venus","avec de la marchandise","qui a peu de qualité,","donne-donc pleinement","à nous","la mesure du volume","et sois charitable","envers nous !","Certes,","Allâh","récompense","les gens charitables."],"89":["Il a dit :","\"Est-ce-que","vous savez","ce que","vous avez fait","de Josef","et son frère","quand","vous","(étiez) ignorants ?\""],"90":["Ils ont dit :","\"Est-ce-que certes, tu","(es) certainement toi","Josef ?\"","il a dit :","\"Je (suis)","Josef","et ceci (est)","mon frère.\"","Certes,","a donné de la faveur","Allâh","à nous.","Certes, [il]","celui qui","est pieux","et est patient,","alors certes,","Allâh","ne","laisse (pas) perdre","la récompense","des bienfaiteurs.\""],"91":["ils ont dit :","\"Par Allâh !","Certes, certainement","t'a préféré","Allâh","à nous !","Et certes,","nous étions","certainement des gens qui font des erreurs.\""],"92":["Il a dit :","\"(Il n'y aura) pas du tout","(de) reproche","à vous","aujourd'hui.","(Que) pardonne","Allâh","à vous.","Et Il (est)","Le Plus Miséricordieux","de ceux qui font miséricorde."],"93":["Prenez","ma tunique","-ci","et ensuite jetez-la","sur","le visage","de mon père,","il (de)viendra","très voyant","et apportez-moi","votre famille","toute entière.\""],"94":["Et quand","est partie","la caravane,","a dit","leur père :","\"Certes, je","trouve certainement","l'odeur","de Josef.","Si ne pas","que","vous me diriez faible en jugement...\""],"95":["Ils ont dit :","\"Par Allâh !","Certes, tu (es)","certainement dans","ton erreur","ancienne !\""],"96":["Et ensuite, quand","[qu']","est venu","l'annonciateur de bonnes nouvelles,","il l'a jeté","sur","son visage,","il est donc redevenu","très voyant.","Il a dit :","\"Est-ce-que ne pas","j'