{"1":["¡Oh!","Profeta","¿Por qué?","te prohíbes","lo que","ha hecho lícito","Allah","para ti","buscando","el agrado","de tus esposas","Y Allah","(es) Indulgente","Misericordioso"],"2":["Ciertamente","ha prescrito","Allah","para ustedes","la anulación","de sus juramentos","Y Allah","es su Protector","y Él","es el Omnisciente","el Sabio"],"3":["Y cuando","confió","el Profeta","a","una","de sus esposas","un secreto","y cuando","ella lo divulgó","sobre ello","y lo reveló","Allah","a él","comunicó","una parte","y evitó","[de]","otra parte","Luego cuando","le informó a ella","sobre ello","ella dijo","¿Quién","te informó","esto?","Él dijo","Me informó","el Omnisciente","el Bien Informado"],"4":["Si","ambas se vuelven","a","Allah","entonces ciertamente","se han inclinado","sus corazones","pero si","se apoyan entre sí","contra él","pues ciertamente","Allah","es Él","su Protector","y Jibreel","y el virtuoso","de los creyentes","y los Ángeles","después de","eso","(son sus) auxiliares"],"5":["Puede que","su Señor","si","las divorciara","[que]","le daría a cambio","esposas","mejores","que ustedes","sumisas","creyentes","devotas","arrepentidas","adoradoras","ayunadoras","casadas previamente","y vírgenes"],"6":["¡Oh!","aquellos que","creen","Protejan","a sí mismos","y a sus familias","(de) un Fuego","cuyo combustible","(son) los hombres","y las piedras","sobre él","(hay) Ángeles","rigurosos","severos","no","desobedecen","a Allah","(en) lo que","Él les ordena","sino que hacen","lo que","se les ordena"],"7":["¡Oh!","aquellos que","no creen","No","presenten excusas","hoy","Solo","serán retribuidos","(por) lo que","solían","hacer"],"8":["¡Oh!","aquellos que","creen","Arrepiéntanse","a","Allah","(con) arrepentimiento","sincero","Quizás","su Señor","[que]","borre","de ustedes","sus faltas","y los admita","(en) Jardines","que fluyen","desde","debajo de ellos","los ríos","el Día","en que no","humillará","Allah","al Profeta","ni a quienes","creyeron","con él","Su luz","correrá","ante","sus manos (frente)","y a su derecha","ellos dirán","¡Señor nuestro!","Completa","para nosotros","nuestra luz","y perdónanos","a nosotros","Ciertamente, Tú","sobre","cada","cosa","eres Todopoderoso"],"9":["¡Oh!","Profeta","Lucha","(contra) los infieles","y los hipócritas","y sé severo","con ellos","y su morada","(es) el Infierno","y qué pésimo es","el destino"],"10":["Presenta","Allah","un ejemplo","para aquellos que","no creyeron","la mujer","(de) Nuh","y la mujer","(de) Lut","Ambas estaban","bajo","dos siervos","de","Nuestros siervos","virtuosos","pero ambas los traicionaron","pero no","pudieron protegerlas","a ninguna de ellas","de","Allah","en nada","y se les dijo","\"Entren","en el Fuego","con","quienes entran\""],"11":["Y presenta","Allah","un ejemplo","para aquellos que","creyeron","la mujer","(de) Firaun","cuando","ella dijo","¡Señor mío!","Construye","para mí","junto a Ti","una casa","en","el Paraíso","y sálvame","de","Firaun","y sus obras","y sálvame","del","pueblo","injusto"],"12":["Y a Maryam","hija","(de) Imran","que","conservó","su castidad","y soplamos","en ella","de","Nuestro Espíritu","Y ella creyó","(en las) Palabras","(de) su Señor","y en Sus Libros","y ella fue","de","las devotas"]}