{"1":["Alif Lam Ra","Estas","(son) las Aleyas","del Libro","y un Corán","claro"],"2":["Quizás","desearán","aquellos que","no creyeron","si","hubieran sido","Musulmanes"],"3":["Déjalos","que coman","y disfruten","y los distraiga","la esperanza","pronto","sabrán"],"4":["Y no","destruimos","ninguna","ciudad","sin que","tuviera para ella","un decreto","conocido"],"5":["No","puede adelantar","ninguna","comunidad","su plazo","y no","pueden retrasarlo"],"6":["Y dicen","Oh tú","a quien","se ha hecho bajar","sobre él","el Recuerdo","ciertamente tú","eres un poseso"],"7":["Por qué","no","nos traes","los Ángeles","si","eres","de","los veraces"],"8":["No","hacemos descender","a los Ángeles","sino","con la verdad","y no","se les daría","entonces","espera"],"9":["Ciertamente, Nosotros","Nosotros","hemos revelado","el Recuerdo","y ciertamente, Nosotros","para él","somos sin duda Guardianes"],"10":["Y ciertamente","enviamos","de","antes de ti","en","las sectas","de los antiguos"],"11":["Y no","les llegaba","ningún","Mensajero","sin que","ellos","de él","se burlaran"],"12":["Así","lo dejamos entrar","en","los corazones","de los malhechores"],"13":["No","creen","en ello","y ciertamente","ha pasado","el ejemplo","de los antiguos"],"14":["Y si","abriéramos","sobre ellos","una puerta","del","cielo","y continuaran","por ella","ascendiendo"],"15":["Seguramente dirían","Solo","han sido deslumbrados","nuestros ojos","sino que","nosotros","somos gente","hechizada"],"16":["Y ciertamente","hemos puesto","en","el cielo","constelaciones","y las hemos adornado","para los observadores"],"17":["Y las hemos protegido","de","todo","demonio","maldito"],"18":["Excepto","quien","escucha a hurtadillas","lo que se oye","entonces le persigue","una llama","brillante"],"19":["Y la tierra","la hemos extendido","y hemos puesto","en ella","montañas firmes","y hemos hecho crecer","en ella","de","toda","cosa","bien proporcionada"],"20":["Y hemos puesto","para vosotros","en ella","medios de vida","y para quien","no sois vosotros","para él","proveedores"],"21":["Y no","hay","cosa","sino","con Nosotros","(están) sus tesoros","y no","lo hacemos descender","excepto","en una medida","conocida"],"22":["Y hemos enviado","los vientos","fecundantes","y hacemos descender","del","cielo","agua","y os la damos a beber","Y no","vosotros","de ella","sois guardianes"],"23":["Y en verdad, Nosotros","ciertamente Nosotros","damos la vida","y damos la muerte","y Nosotros","somos los Herederos"],"24":["Y ciertamente","conocemos","a los que os preceden","de vosotros","y ciertamente","conocemos","a los que vienen después"],"25":["Y en verdad","tu Señor","Él","los congregará","Ciertamente, Él","es Sabio","Conocedor"],"26":["Y ciertamente","creamos","al hombre","de","arcilla sonora","de","barro","moldeable"],"27":["Y al genio","lo creamos","de","antes","de","fuego","abrasador"],"28":["Y cuando","dijo","tu Señor","a los Ángeles","Ciertamente, Yo","voy a crear","un ser humano","de","arcilla","de","barro","moldeable"],"29":["Así que, cuando","lo haya formado","y haya soplado","en él","de","Mi espíritu","entonces caed","ante él","postrados"],"30":["Así que se postraron","los Ángeles","todos ellos","juntos"],"31":["Excepto","Iblis","se negó","a","estar","con","los que se postraban"],"32":["Dijo","¡Oh, Iblis!","¿Qué","te pasa","que no","estés","con","los que se postran"],"33":["Dijo","No","he de ser","quien se postre","a un humano","a quien creaste","de","arcilla","de","barro","moldeable"],"34":["Dijo","Entonces sal","de aquí","pues ciertamente tú","eres maldito"],"35":["Y en verdad","sobre ti","(está) la maldición","hasta","el Día","del Juicio"],"36":["Dijo","Señor mío","Entonces, dame un plazo","hasta","el Día","sean resucitados"],"37":["Dijo","Entonces ciertamente tú","eres de","los que tienen un plazo"],"38":["Hasta","el Día","del tiempo","conocido"],"39":["Dijo","Mi Señor","Puesto que","me extraviaste","ciertamente embelleceré","para ellos","en","la tierra","y los extraviaré","a todos"],"40":["Excepto","Tus siervos","de entre ellos","los escogidos"],"41":["Dijo","Este","es un camino","hacia Mí","recto"],"42":["En verdad","Mis siervos","no","tienes","sobre ellos","ninguna autoridad","excepto","quien","te siga","de","los extraviados"],"43":["Y en verdad","el Infierno","es el lugar prometido para ellos","todos"],"44":["Tiene","siete","puertas","para cada","puerta","de ellos","una porción","asignada"],"45":["En verdad","los piadosos","estarán en","Jardines","y manantiales"],"46":["Entrad en ellos","en paz","seguros"],"47":["Y quitaremos","lo que","está en","sus pechos","de","rencor","(como) hermanos","sobre","tronos","unos frente a otros"],"48":["No","les tocará","allí","fatiga","y no","ellos","de allí","serán sacados"],"49":["Informa","a Mis siervos","que Yo","Yo soy","el Perdonador","el Misericordioso"],"50":["Y que","Mi castigo","es","el castigo","el doloroso"],"51":["E infórmales","sobre","los huéspedes","de Abraham"],"52":["Cuando","entraron","ante él","y dijeron","¡Paz!","Dijo","En verdad, nosotros","de vosotros","tememos"],"53":["Dijeron","No","temas","en verdad, nosotros","te anunciamos","un niño","sabio"],"54":["Dijo","¿Me anunciáis","a pesar","de que","me ha alcanzado","la vejez","Entonces, ¿sobre qué","me anunciáis?"],"55":["Dijeron","Te anunciamos","con la verdad","así que no","seas","de","los que desesperan"],"56":["Dijo","¿Y quién","desespera","de","la misericordia","de su Señor","sino","los extraviados"],"57":["Dijo","Entonces, ¿cuál","es vuestra misión","oh","enviados"],"58":["Dijeron","En verdad, nosotros","hemos sido enviados","a","un pueblo","de malhechores"],"59":["Excepto","la familia","de Lot","ciertamente, nosotros","seguramente los salvaremos","a todos"],"60":["Excepto","su mujer","hemos decretado","que ella","es ciertamente de","los que se quedan atrás"],"61":["Y cuando","llegaron","a la familia","de Lot","los enviados"],"62":["Dijo","En verdad, vosotros","sois un pueblo","desconocido"],"63":["Dijeron","Al contrario","hemos venido a ti","co