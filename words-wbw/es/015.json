["Y ciertamente","te hemos dado","siete","de","los que se repiten","y el Corán","grandioso"],"88":["No","extiendas","tus ojos","hacia","lo que","hemos concedido","con ello","a categorías","de ellos","y no","te aflijas","por ellos","Y baja","tu ala","para los creyentes"],"89":["Y di","En verdad, Yo","soy","el amonestador","claro"],"90":["Como","hicimos descender","sobre","los que dividieron"],"91":["Aquellos que","han hecho","el Corán","en partes"],"92":["Así que, por tu Señor","ciertamente les preguntaremos","a todos"],"93":["Sobre lo que","solían","hacer"],"94":["Así que proclama","lo que","se te ordena","y apártate","de","los idólatras"],"95":["En verdad, Nosotros","te bastamos","contra los burladores"],"96":["Aquellos que","ponen","junto a","Allah","un dios","otro","¡Pronto","sabrán!"],"97":["Y ciertamente","sabemos","que tú","se oprime","tu pecho","por lo que","dicen"],"98":["Así que glorifica","con la alabanza","de tu Señor","y sé","de","los que se postran"],"99":["Y adora","a tu Señor","hasta que","te llegue","la certeza"]}