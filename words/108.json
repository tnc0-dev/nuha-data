{"surah":108,"ayahs":{"1":[{"position":1,"text_arabic":"إِنَّآ","transliteration":"innā","translation":"Indeed, We","translation_tr":"elbette biz"},{"position":2,"text_arabic":"أَعْطَيْنَـٰكَ","transliteration":"aʿṭaynāka","translation":"We have given you","translation_tr":"sana verdik"},{"position":3,"text_arabic":"ٱلْكَوْثَرَ","transliteration":"l-kawthara","translation":"Al-Kauthar","translation_tr":"Kevser'i"}],"2":[{"position":1,"text_arabic":"فَصَلِّ","transliteration":"faṣalli","translation":"So pray","translation_tr":"öyleyse namaz kıl"},{"position":2,"text_arabic":"لِرَبِّكَ","transliteration":"lirabbika","translation":"to your Lord","translation_tr":"Rabbin için"},{"position":3,"text_arabic":"وَٱنْحَرْ","transliteration":"wa-in'ḥar","translation":"and sacrifice","translation_tr":"ve kurban kes"}],"3":[{"position":1,"text_arabic":"إِنَّ","transliteration":"inna","translation":"Indeed","translation_tr":"şüphesiz"},{"position":2,"text_arabic":"شَانِئَكَ","transliteration":"shāni-aka","translation":"your enemy ","translation_tr":"sana buğzeden"},{"position":3,"text_arabic":"هُوَ","transliteration":"huwa","translation":"he (is)","translation_tr":"o"},{"position":4,"text_arabic":"ٱلْأَبْتَرُ","transliteration":"l-abtaru","translation":"the one cut off","translation_tr":"sonu kesik olandır"}]}}